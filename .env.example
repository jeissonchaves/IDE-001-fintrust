# Copia este archivo a .env y completa con tus valores reales.
# NUNCA versiones el archivo .env real.

# ID del proyecto GCP (obligatorio)
GCP_PROJECT_ID=mi-proyecto-gcp-123

# Nombre del bucket GCS para staging de CSVs
# Si no se define, el pipeline usa: {GCP_PROJECT_ID}-fintrust-raw
GCS_BUCKET=mi-proyecto-gcp-123-fintrust-raw




